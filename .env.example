# 数据库配置
DATABASE_URL=sqlite:///./data/tool_store.db
REDIS_URL=redis://localhost:6379/0

# Claude API配置
CLAUDE_API_KEY=
CLAUDE_BASE_URL=https://api.anthropic.com

# 智谱AI Embedding配置
